# --- App ---
APP_ENV=dev
APP_DEBUG=true
APP_URL=http://motociclete.test

# Subfolderul din care e servită aplicația (gol = rădăcina site-ului).
# Staging pe cPanel: BASE_PATH=/2026 (vezi DEPLOY.md). Local: lasă gol.
BASE_PATH=
# Cache pe disc pentru Twig (true doar pe prod; necesită storage/cache scriibil).
TWIG_CACHE=false
# Unde duc butoanele „Drive test" (modulul drivetest).
TESTRIDE_URL=https://www.motociclete.com.ro/drive-test/

# --- Email (PHPMailer / SMTP) ---
# Pe DEV lasă SMTP_HOST gol → emailurile se scriu în storage/logs/mail.log.
# Pe PROD completează contul cPanel pentru noreply@motociclete.com.ro
# (tipic: SMTP_HOST=mail.motociclete.com.ro, SMTP_PORT=465, SMTP_SECURE=ssl).
MAIL_FROM=noreply@motociclete.com.ro
MAIL_FROM_NAME=Dual Motors
MAIL_DEALER=info@motociclete.com.ro
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

# --- Admin back-office ---
# Cale URL ascunsă a panoului (NU folosi „admin"). Schimb-o pe staging/prod.
ADMIN_PATH=dm-control
# Userii admin sunt în tabela admin_users (creează primul cu database/seed_admin_user.php).
# ADMIN_USER/ADMIN_PASS rămân doar pentru vechiul guard de fitment (fallback).
ADMIN_USER=admin
ADMIN_PASS=

# --- Local portal database (Dual Motors) ---
# Pe staging: DB_LOCAL_NAME=dualmotors_motociclete2026, host=localhost.
DB_LOCAL_HOST=127.0.0.1
DB_LOCAL_PORT=3306
DB_LOCAL_NAME=dualmotors_portal
DB_LOCAL_USER=root
DB_LOCAL_PASS=

# --- BikerShop (PrestaShop 9) - READ ONLY ---
# Leave blank until real read-only credentials are provided.
BIKERSHOP_HOST=
BIKERSHOP_PORT=3306
BIKERSHOP_NAME=
BIKERSHOP_USER=
BIKERSHOP_PASS=
BIKERSHOP_PREFIX=ps_
BIKERSHOP_LANG_ID=1
BIKERSHOP_BASE_URL=https://bikershop.ro

# --- Legacy source DBs (Yamaha/CFMOTO) — DOAR pentru database/migrate_catalog.php ---
# Nu sunt necesare la runtime. Lasă-le goale în afara migrării locale.
DM_HOST=
DM_PORT=3306
DM_USER=
DM_PASS=
DM_DB_MOTO=dualmotors_motociclete
DM_DB_CFMOTO=dualmotors_cfmoto
