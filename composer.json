{
    "name": "dualmotors/motociclete",
    "description": "Portal motociclete.com.ro - Dual Motors. Showroom + integrare BikerShop (PrestaShop 9).",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "phpmailer/phpmailer": "^7.1",
        "slim/psr7": "^1.6",
        "slim/slim": "^4.12",
        "slim/twig-view": "^3.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.1.10"
        }
    }
}
