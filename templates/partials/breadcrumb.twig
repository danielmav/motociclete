<nav class="breadcrumb" aria-label="Breadcrumb">
    <div class="container">
        <ol class="breadcrumb__list">
            <li><a href="{{ base }}/">Acasă</a></li>
            {% for c in crumbs %}
                <li>
                    {% if c.url %}<a href="{{ base }}{{ c.url }}">{{ c.label }}</a>
                    {% else %}<span aria-current="page">{{ c.label }}</span>{% endif %}
                </li>
            {% endfor %}
        </ol>
    </div>
</nav>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Acasă", "item": "{{ app.url ~ base }}/" }
    {%- for c in crumbs -%}
    ,{ "@type": "ListItem", "position": {{ loop.index + 1 }}, "name": {{ c.label|json_encode|raw }}{% if c.url %}, "item": "{{ app.url ~ base ~ c.url }}"{% endif %} }
    {%- endfor -%}
  ]
}
</script>
