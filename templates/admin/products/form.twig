{% extends 'admin/layout.twig' %}
{% set active = 'products' %}
{% block title %}{{ id > 0 ? 'Editează produs' : 'Produs nou' }}{% endblock %}

{% macro editor(name, value) %}
    <div class="adm-editor" data-editor="{{ name }}">{{ value|raw }}</div>
    <textarea name="{{ name }}" hidden>{{ value }}</textarea>
{% endmacro %}

{% macro imgmgr(name, type, brand, single, items) %}
    <div class="adm-imgmgr" data-imgmgr {{ single ? 'data-single' }} data-context="product" data-brand="{{ brand }}" data-type="{{ type }}" data-name="{{ name }}">
        <div class="adm-drop" data-dropzone>Trage imagini aici sau click</div>
        <div class="adm-imgs" data-images>
            {% for it in items %}
                <div class="adm-img" data-filename="{{ it.filename }}" {{ single ? '' : 'draggable=true' }}>
                    <img src="{{ base }}/media/{{ brand }}/{{ {'color':'culori','gallery':'motociclete','detail':'detalii','cover':'cover'}[type] }}/{{ it.filename|url_encode }}" alt="">
                    <div class="adm-img__bar">
                        {{ single ? '' : '<span class="adm-img__btn" data-move>↕</span>' }}
                        <button type="button" class="adm-img__btn" data-del>Șterge</button>
                    </div>
                    <input type="hidden" name="{{ name }}{{ single ? '' : '[]' }}" value="{{ it.filename }}">
                </div>
            {% endfor %}
        </div>
    </div>
{% endmacro %}

{% import _self as f %}

{% block flash %}
    {{ parent() }}
    {% if fromYamaha is defined and fromYamaha %}
        <div class="adm-flash adm-flash--ok">Date pre-completate de la Yamaha. <strong>Verifică</strong> totul (mai ales prețul — nu vine de la Yamaha) și ordonează/șterge imaginile, apoi apasă <strong>Salvează</strong>. Nimic nu e salvat până nu salvezi.</div>
    {% endif %}
    {% if sync is defined and sync %}
        <div class="adm-flash adm-flash--ok">Accesorii sincronizate: {{ sync.fetched }} ({{ sync.new }} noi{% if sync.unmatched %}, {{ sync.unmatched }} fără produs pe bikershop{% endif %}).</div>
    {% endif %}
    {% if syncErr is defined and syncErr %}
        <div class="adm-flash adm-flash--err">Sincronizarea accesoriilor a eșuat (Yamaha indisponibil?). Produsul a fost salvat oricum.</div>
    {% endif %}
{% endblock %}

{% block content %}
<form class="adm-form" method="post" action="{{ admin_base }}/produse/{{ id }}" style="max-width:1100px">
    <input type="hidden" name="_csrf" value="{{ csrf }}">
    {# Produsul-motocicletă BikerShop (tab OEM). Pre-completat → păstrat la editări. #}
    <input type="hidden" name="bs_product_id" value="{{ p.bs_product_id|default('') }}">

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Date de bază</span>
        <div class="adm-grid3" style="margin-top:.8rem">
            <label>Brand
                <select name="brand" id="p-brand">
                    <option value="yamaha" {{ brand == 'yamaha' ? 'selected' }}>Yamaha</option>
                    <option value="cfmoto" {{ brand == 'cfmoto' ? 'selected' }}>CFMOTO</option>
                </select>
            </label>
            <label>Categorie
                <select name="category_id" id="p-cat"><option value="0">—</option></select>
            </label>
            <label>An
                <input type="number" name="year" value="{{ p.year|default('') }}">
            </label>
        </div>
        <div class="adm-grid2" style="margin-top:.8rem">
            <label>Nume model
                <input type="text" id="p-name" name="name" value="{{ p.name|default('') }}" required>
            </label>
            <label>Slug <span class="adm-help">gol = generat din nume</span>
                <input type="text" id="p-slug" name="slug" data-slug-from="#p-name" value="{{ p.slug|default('') }}">
            </label>
        </div>
        <label style="margin-top:.8rem">Slogan model
            <input type="text" name="subtitle" value="{{ p.subtitle|default('') }}">
        </label>
        <div class="adm-grid3" style="margin-top:.8rem">
            <label>Preț (EUR, cu TVA)
                <input type="number" name="price" value="{{ p.price|default(0) }}">
            </label>
            <label>Reducere (%)
                <input type="text" name="discount_pct" value="{{ p.discount_pct|default(0) }}">
            </label>
            <label>Permis <span class="adm-help">A1 / A2 / A</span>
                <input type="text" name="licence" value="{{ p.licence|default('') }}">
            </label>
        </div>
        <div class="adm-grid2" style="margin-top:.8rem">
            <label>Video YouTube (ID)
                <input type="text" name="video" value="{{ p.video|default('') }}">
            </label>
            <label>Cuvinte cheie (SEO)
                <input type="text" name="keywords" value="{{ p.keywords|default('') }}">
            </label>
        </div>
        {% if brand == 'yamaha' %}
        <div class="adm-grid2" style="margin-top:.8rem">
            <label>PID accesorii Yamaha <span class="adm-help">ID-ul din pagina de accesorii Yamaha (ex. 288454). La salvare, dacă PID-ul e nou/schimbat, accesoriile se sincronizează automat.</span>
                <input type="text" name="yamaha_pid" value="{{ p.yamaha_pid|default('') }}" placeholder="ex. 288454">
            </label>
            {% if id > 0 and p.yamaha_pid %}
            <div style="display:flex;align-items:flex-end">
                <button type="submit" class="btn btn--ghost btn--sm" formaction="{{ admin_base }}/produse/{{ id }}/sync-accesorii" formnovalidate>↻ Resincronizează accesorii</button>
            </div>
            {% endif %}
        </div>
        <p class="adm-muted" style="margin-top:.4rem;font-size:.85em">
            {% if p.bs_product_id|default(0) %}Fitment BikerShop (piese OEM): legat de produsul #{{ p.bs_product_id }}.{% else %}Fitment BikerShop: nelegat. Rulează <code>migrate_bs_models.php</code> pentru maparea pe nume.{% endif %}
        </p>
        {% endif %}
    </div>

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Imagine principală (meniu + carduri)</span>
        <div style="margin-top:.6rem">{{ f.imgmgr('cover_image', 'cover', brand, true, p.cover_image ? [{filename: p.cover_image}] : []) }}</div>
    </div>

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Imagini culori</span>
        <div style="margin-top:.6rem">{{ f.imgmgr('color', 'color', brand, false, images.color|default([])) }}</div>
    </div>

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Galerie</span>
        <div style="margin-top:.6rem">{{ f.imgmgr('gallery', 'gallery', brand, false, images.gallery|default([])) }}</div>
    </div>

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Imagini detalii</span>
        <div style="margin-top:.6rem">{{ f.imgmgr('detail', 'detail', brand, false, images.detail|default([])) }}</div>
    </div>

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Descriere scurtă</span>
        <div style="margin-top:.6rem">{{ f.editor('excerpt', p.excerpt|default('')) }}</div>
    </div>
    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Descriere lungă</span>
        <div style="margin-top:.6rem">{{ f.editor('description', p.description|default('')) }}</div>
    </div>
    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Promoții <span class="adm-help">apare în tabul „Descriere”, după text, într-o casetă evidențiată „Nu rata această promoție”. Gol = nu se afișează.</span></span>
        <div style="margin-top:.6rem">{{ f.editor('promo_html', p.promo_html|default('')) }}</div>
    </div>
    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Caracteristici cheie</span>
        <div style="margin-top:.6rem">{{ f.editor('details_html', p.details_html|default('')) }}</div>
    </div>

    {% for key, label in {'engine':'Motor','chassis':'Șasiu','dimensions':'Dimensiuni','connectivity':'Conectivitate'} %}
        <div class="adm-fieldset">
            <span class="adm-fieldset__t">Specificații · {{ label }}</span>
            <div class="adm-rows" id="spec-{{ key }}" data-rows style="margin-top:.6rem">
                {% for r in specRows[key]|default([]) %}
                    <div class="adm-row">
                        <input type="text" name="spec_{{ key }}_label[]" value="{{ r.label }}" placeholder="Caracteristică">
                        <input type="text" name="spec_{{ key }}_value[]" value="{{ r.value }}" placeholder="Valoare">
                        <button type="button" class="adm-row__del" data-row-del>×</button>
                    </div>
                {% endfor %}
                <template data-row-tpl>
                    <div class="adm-row">
                        <input type="text" name="spec_{{ key }}_label[]" placeholder="Caracteristică">
                        <input type="text" name="spec_{{ key }}_value[]" placeholder="Valoare">
                        <button type="button" class="adm-row__del" data-row-del>×</button>
                    </div>
                </template>
            </div>
            <button type="button" class="adm-btn adm-btn--sm" data-row-add="#spec-{{ key }}" style="margin-top:.5rem">+ rând</button>
        </div>
    {% endfor %}

    <div class="adm-fieldset">
        <span class="adm-fieldset__t">Prețuri variante <span class="adm-help">apare ca tabul „Preturi” doar la modelele cu mai multe variante (ex. putere/transmisie). Prețul = EUR cu TVA; se afișează EUR + RON (la curs). Gol = fără tab.</span></span>
        <div class="adm-rows" id="variant-rows" data-rows style="margin-top:.6rem">
            {% for r in variantRows|default([]) %}
                <div class="adm-row adm-row--3">
                    <input type="text" name="var_version[]" value="{{ r.version }}" placeholder="Versiune (ex. Maxima / 35kW A2)">
                    <input type="text" name="var_transmission[]" value="{{ r.transmission }}" placeholder="Transmisie (ex. Y-AMT)">
                    <input type="number" name="var_price[]" value="{{ r.price }}" placeholder="Preț EUR">
                    <button type="button" class="adm-row__del" data-row-del>×</button>
                </div>
            {% endfor %}
            <template data-row-tpl>
                <div class="adm-row adm-row--3">
                    <input type="text" name="var_version[]" placeholder="Versiune (ex. Maxima / 35kW A2)">
                    <input type="text" name="var_transmission[]" placeholder="Transmisie (ex. Y-AMT)">
                    <input type="number" name="var_price[]" placeholder="Preț EUR">
                    <button type="button" class="adm-row__del" data-row-del>×</button>
                </div>
            </template>
        </div>
        <button type="button" class="adm-btn adm-btn--sm" data-row-add="#variant-rows" style="margin-top:.5rem">+ variantă</button>
    </div>

    <div class="adm-grid2">
        <label>Poziție
            <input type="number" name="position" value="{{ p.position|default(0) }}">
        </label>
        <label style="flex-direction:row;align-items:center;gap:.5rem;margin-top:1.6rem">
            <input type="checkbox" name="is_active" value="1" {{ p.is_active is not defined or p.is_active ? 'checked' }} style="width:auto"> Activ
        </label>
    </div>

    <div class="adm-actions">
        <button class="adm-btn adm-btn--primary" type="submit">Salvează</button>
        <a class="adm-btn" href="{{ admin_base }}/produse{{ back_qs|default('') }}">Înapoi</a>
    </div>
</form>
{% endblock %}

{% block scripts %}
<script>
(function(){
  var CATS = {{ categories|json_encode|raw }};
  var CURRENT = {{ p.category_id|default(0) }};
  var brandSel = document.getElementById('p-brand');
  var catSel = document.getElementById('p-cat');
  function fillCats(){
    var b = brandSel.value;
    catSel.innerHTML = '<option value="0">—</option>';
    CATS.filter(function(c){return c.brand===b;}).forEach(function(c){
      var o=document.createElement('option'); o.value=c.id; o.textContent=c.label;
      if(c.id==CURRENT) o.selected=true; catSel.appendChild(o);
    });
  }
  // keep upload target folders in sync with the selected brand
  function syncBrand(){
    document.querySelectorAll('[data-imgmgr]').forEach(function(m){ m.setAttribute('data-brand', brandSel.value); });
  }
  brandSel.addEventListener('change', function(){ fillCats(); syncBrand(); });
  fillCats();
})();
</script>
{% endblock %}
