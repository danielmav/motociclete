{% extends 'layout.twig' %}

{% block title %}Editare motocicletă — Admin | Dual Motors{% endblock %}
{% block description %}Editare date motocicletă client.{% endblock %}

{% block content %}
<section class="section">
    <div class="container admin">
        <a class="link-arrow link-arrow--sm" href="{{ base }}/admin/garage">← Clienți & motociclete</a>
        <h1 class="catalog-head__title">{{ bike.product_name ?: bike.model_label }}</h1>
        <p class="catalog-head__lead">Proprietar: <strong>{{ bike.owner }}</strong> · {{ bike.email_norm }}{% if bike.telefon_norm %} · {{ bike.telefon_norm }}{% endif %}</p>
        {% if saved %}<p class="admin__flash">✓ Salvat.</p>{% endif %}

        {# ---- Profile ---- #}
        <h2 class="section__title" style="font-size:1.2rem;margin-top:1.5rem;">Date motocicletă</h2>
        <form class="admin__form" method="post" action="{{ base }}/admin/garage/moto/{{ bike.id }}">
            <input type="hidden" name="action" value="profile">
            <label class="admin__field"><span>Model din catalog</span>
                <select name="product_id">
                    <option value="">— nelegat (afișează „{{ bike.model_label }}") —</option>
                    {% for p in products %}
                        <option value="{{ p.id }}" {{ bike.product_id == p.id ? 'selected' }}>{{ p.brand|capitalize }} · {{ p.name }}{% if p.year %} ({{ p.year }}){% endif %}</option>
                    {% endfor %}
                </select>
            </label>
            <label class="admin__field"><span>Poreclă</span><input type="text" name="nickname" value="{{ bike.nickname }}"></label>
            <label class="admin__field"><span>An</span><input type="number" name="year" value="{{ bike.year }}" min="1990" max="2030"></label>
            <label class="admin__field"><span>VIN</span><input type="text" name="vin" value="{{ bike.vin }}"></label>
            <label class="admin__field"><span>Culoare</span><input type="text" name="color" value="{{ bike.color }}"></label>
            <label class="admin__field"><span>Număr înmatriculare</span><input type="text" name="plate" value="{{ bike.plate }}"></label>
            <label class="admin__field"><span>Kilometraj</span><input type="number" name="mileage_km" value="{{ bike.mileage_km }}" min="0"></label>
            <label class="admin__field"><span>Data achiziției</span><input type="date" name="purchase_date" value="{{ bike.purchase_date }}"></label>
            <label class="admin__field"><span>Note</span><textarea name="notes" rows="2">{{ bike.notes }}</textarea></label>
            <button class="btn btn--primary" type="submit">Salvează datele</button>
        </form>

        {# ---- Service history ---- #}
        <h2 class="section__title" style="font-size:1.2rem;margin-top:2rem;">Istoric revizii</h2>
        {% if service|length %}
            <table class="compare history">
                <thead><tr><th>Data</th><th>Km</th><th>Tip</th><th>Detalii</th><th>Cost</th><th>Executat de</th></tr></thead>
                <tbody>{% for s in service %}<tr><td>{{ s.service_date ?: '—' }}</td><td>{{ s.mileage_km ?: '—' }}</td><td>{{ s.type ?: '—' }}</td><td>{{ s.description ?: '—' }}</td><td>{{ s.cost_ron ? (s.cost_ron ~ ' lei') : '—' }}</td><td>{{ s.performed_by ?: '—' }}</td></tr>{% endfor %}</tbody>
            </table>
        {% endif %}
        <form class="admin__form" method="post" action="{{ base }}/admin/garage/moto/{{ bike.id }}" style="flex-flow:row wrap;gap:.6rem;align-items:flex-end;">
            <input type="hidden" name="action" value="service">
            <label class="admin__field"><span>Data</span><input type="date" name="service_date" required></label>
            <label class="admin__field"><span>Km</span><input type="number" name="mileage_km" min="0"></label>
            <label class="admin__field"><span>Tip</span><input type="text" name="type" placeholder="revizie / reparație"></label>
            <label class="admin__field" style="flex:1;min-width:200px;"><span>Detalii</span><input type="text" name="description"></label>
            <label class="admin__field"><span>Cost (lei)</span><input type="text" name="cost_ron" inputmode="decimal"></label>
            <label class="admin__field"><span>Executat de</span><input type="text" name="performed_by"></label>
            <button class="btn btn--primary" type="submit">+ Adaugă revizie</button>
        </form>

        {# ---- Incidents ---- #}
        <h2 class="section__title" style="font-size:1.2rem;margin-top:2rem;">Evenimente / accidente</h2>
        {% if incidents|length %}
            <table class="compare history">
                <thead><tr><th>Data</th><th>Gravitate</th><th>Descriere</th></tr></thead>
                <tbody>{% for i in incidents %}<tr><td>{{ i.incident_date ?: '—' }}</td><td>{{ i.severity ?: '—' }}</td><td>{{ i.description ?: '—' }}</td></tr>{% endfor %}</tbody>
            </table>
        {% endif %}
        <form class="admin__form" method="post" action="{{ base }}/admin/garage/moto/{{ bike.id }}" style="flex-flow:row wrap;gap:.6rem;align-items:flex-end;">
            <input type="hidden" name="action" value="incident">
            <label class="admin__field"><span>Data</span><input type="date" name="incident_date" required></label>
            <label class="admin__field"><span>Gravitate</span><input type="text" name="severity" placeholder="minor / mediu / major"></label>
            <label class="admin__field" style="flex:1;min-width:240px;"><span>Descriere</span><input type="text" name="description"></label>
            <button class="btn btn--primary" type="submit">+ Adaugă eveniment</button>
        </form>
    </div>
</section>
{% endblock %}
