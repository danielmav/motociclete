{% extends 'admin/layout.twig' %}
{% set active = 'events' %}
{% block title %}Evenimente{% endblock %}
{% block actions %}<a class="adm-btn adm-btn--primary" href="{{ admin_base }}/evenimente/0">+ Eveniment nou</a>{% endblock %}

{% block content %}
    <table class="adm-table">
        <thead><tr><th></th><th>Titlu</th><th>Locație</th><th>Început</th><th>Status</th><th></th></tr></thead>
        <tbody>
        {% for e in events %}
            <tr>
                <td>{% if e.cover_image %}<img class="adm-thumb" src="{{ base }}/media/evenimente/{{ e.cover_image|url_encode }}" alt="">{% endif %}</td>
                <td><strong>{{ e.title }}</strong><br><span class="adm-muted">{{ e.slug }}</span></td>
                <td class="adm-muted">{{ e.location }}</td>
                <td class="adm-muted">{{ e.starts_at ? e.starts_at|date('d.m.Y H:i') }}</td>
                <td>{% if e.is_active %}<span class="adm-badge adm-badge--on">activ</span>{% else %}<span class="adm-badge adm-badge--off">ascuns</span>{% endif %}</td>
                <td style="white-space:nowrap">
                    <a class="adm-btn adm-btn--sm" href="{{ admin_base }}/evenimente/{{ e.id }}">Editează</a>
                    <form method="post" action="{{ admin_base }}/evenimente/{{ e.id }}/delete" style="display:inline" onsubmit="return confirm('Ștergi evenimentul?')">
                        <input type="hidden" name="_csrf" value="{{ csrf }}">
                        <button class="adm-btn adm-btn--sm adm-btn--danger" type="submit">Șterge</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6" class="adm-muted">Niciun eveniment. Adaugă primul.</td></tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
