{% extends 'layout.twig' %}

{% block title %}{{ p.name }}{% if p.year %} {{ p.year }}{% endif %} — {{ brandLabel }} | Dual Motors{% endblock %}
{% block description %}{{ p.excerpt ? (p.excerpt|striptags|trim|slice(0, 155)) : (p.name ~ ' ' ~ brandLabel ~ ' la Dual Motors — preț, dotări, culori și test ride.') }}{% endblock %}

{% block content %}

{% include 'partials/breadcrumb.twig' %}

{% set mainImage = p.cover ?: (gallery|length ? gallery[0].src : (colors|length ? colors[0].src : null)) %}

<article class="product">
    <div class="container product__grid">

        {# ---------------- Media ---------------- #}
        <div class="product__media">
            <div class="gallery">
                <div class="gallery__stage{{ mainImage ? '' : ' media-ph' }}" data-gallery>
                    {% if mainImage %}
                        <img class="gallery__main" data-gallery-main src="{{ base }}{{ mainImage }}" alt="{{ p.name }}"
                             width="1280" height="853" fetchpriority="high"
                             onerror="this.closest('.gallery__stage').classList.add('media-ph');this.remove()">
                    {% else %}
                        <span class="media-ph__label">{{ p.name }}</span>
                    {% endif %}
                </div>

                {# Hero thumbnails: color variants only — the rest of the imagery
                   (gallery + details) lives in the "Galerie" tab below. #}
                {% if colors|length > 1 %}
                    <ul class="gallery__thumbs">
                        {% for t in colors %}
                            <li>
                                <button type="button" class="gallery__thumb{{ loop.first ? ' is-active' : '' }}"
                                        data-gallery-thumb data-src="{{ base }}{{ t.src }}" aria-label="Culoare {{ loop.index }}">
                                    <img src="{{ base }}{{ t.src }}" alt="" loading="lazy" width="120" height="80"
                                         onerror="this.closest('li').remove()">
                                </button>
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </div>

        {# ---------------- Summary ---------------- #}
        <div class="product__summary">
            {% if p.subtitle %}<span class="kicker">{{ p.subtitle }}</span>{% endif %}
            <h1 class="product__title">{{ p.name }}</h1>

            <div class="product__meta">
                <span class="chip">{{ brandLabel }}</span>
                {% if p.cat_name %}<span class="chip">{{ p.cat_name }}</span>{% endif %}
                {% if p.year %}<span class="chip chip--ghost">{{ p.year }}</span>{% endif %}
                {% if p.licence %}<span class="chip chip--permis">Permis {{ p.licence }}</span>{% endif %}
            </div>

            {% if p.price %}
            <div class="product__price-row">
                {% set now = prices(p.price) %}
                <div class="product__price">
                    {% if p.old_price %}<span class="badge badge--sale">−{{ p.discount_pct|round }}%</span>{% endif %}
                    <div class="price__main">
                        <span class="price__now">{{ now.eur }}</span>
                        <span class="price__now-ron">{{ now.ron }}</span>
                    </div>
                    {% if p.old_price %}
                        {% set old = prices(p.old_price) %}
                        <s class="price__old">{{ old.eur }} · {{ old.ron }}</s>
                    {% endif %}
                    <span class="product__price-note">preț cu TVA {{ currency.vat }}% · curs {{ currency.rate }} lei/€</span>
                </div>

                {% if financePriceRon and financeRates|length %}
                    {% set defaultTerm = (financeRates|keys|last) %}
                    <div class="finance-calc" id="unicredit-calculator" data-rates='{{ financeRates|json_encode }}'>
                        <div class="finance-calc__head">
                            <span class="finance-calc__brand">Rate UniCredit</span>
                            <select id="fc-term" class="finance-calc__term" data-fc-term aria-label="Durată credit">
                                {% for n in financeRates|keys %}
                                    <option value="{{ n }}"{{ n == defaultTerm ? ' selected' : '' }}>{{ n }} luni</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="finance-calc__result">
                            <span class="finance-calc__rate" data-fc-rate>{{ financeRates[defaultTerm]|number_format(2, ',', '.') }} lei</span>
                            <span class="finance-calc__per">/lună</span>
                        </div>
                        <div class="finance-calc__foot">
                            <span>{{ financePriceRon|number_format(0, ',', '.') }} lei{% if financeCfg %} · DAE {{ financeCfg.dae|number_format(1, ',', '.') }}%{% endif %}</span>
                            <a class="link-arrow link-arrow--sm" href="{{ base }}/finantare"{% if financeCfg and financeCfg.page_html %} data-modal-open="finantare"{% endif %}>Detalii →</a>
                        </div>
                    </div>
                {% endif %}
            </div>
            {% endif %}

            {% if p.excerpt %}<div class="product__excerpt">{{ p.excerpt|raw }}</div>{% endif %}

            {% set wamsg = ('Bună ziua, sunt interesat de ' ~ p.name ~ (p.year ? ' ' ~ p.year : '') ~ '. Aș dori detalii.')|url_encode %}
            <div class="product__actions">
                <button type="button" class="btn btn--primary btn--sm" data-modal-open="test-ride">Programează test ride</button>
                <button type="button" class="btn btn--ghost btn--sm" data-modal-open="oferta">Cere ofertă</button>
                <a class="btn btn--wa btn--sm" href="https://wa.me/40722354437?text={{ wamsg }}" target="_blank" rel="noopener" aria-label="Scrie-ne pe WhatsApp">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2Zm5.8 14.16c-.24.68-1.4 1.3-1.94 1.34-.5.05-.97.23-3.27-.68-2.76-1.09-4.5-3.92-4.64-4.1-.13-.18-1.1-1.46-1.1-2.79s.7-1.98.95-2.25c.24-.27.53-.34.7-.34l.5.01c.16.01.38-.06.59.45.24.58.81 2 .88 2.14.07.14.12.31.02.49-.09.18-.14.29-.27.45-.14.16-.29.36-.41.48-.14.14-.28.29-.12.57.16.27.71 1.17 1.53 1.9 1.05.93 1.94 1.22 2.22 1.36.27.14.43.12.59-.07.16-.18.68-.79.86-1.07.18-.27.36-.22.6-.13.25.09 1.57.74 1.84.88.27.14.45.2.51.31.07.11.07.63-.17 1.32Z"/></svg>
                    WhatsApp
                </a>
                <a class="btn btn--call btn--sm" href="tel:0722354437" aria-label="Sună la 0722 354 437">0722 354 437</a>
            </div>

            {% if colors|length %}
                <p class="product__colors-note">{{ colors|length }} {{ colors|length == 1 ? 'variantă de culoare' : 'variante de culoare' }} disponibile</p>
            {% endif %}
        </div>
    </div>

    {# ===== Product tabs: descriere / caracteristici / specificații / galerie / piese ===== #}
    {% set accCount = (oemParts|default([])|length) + (accessories|default([])|length) %}
    {% set specs = [
        { id: 'motor', label: 'Motor',              html: p.specs_engine },
        { id: 'sasiu', label: 'Șasiu & suspensii',  html: p.specs_chassis },
        { id: 'dim',   label: 'Dimensiuni',         html: p.specs_dimensions },
        { id: 'conn',  label: 'Conectivitate',      html: p.specs_connectivity }
    ]|filter(s => s.html|trim is not empty) %}
    {% set galImages = (gallery|default([]))|merge(details|default([])) %}
    {% set hasGalerie = galImages|length or p.video %}

    {% set tabs = [] %}
    {% if p.description %}{% set tabs = tabs|merge([{ id: 'descriere', label: 'Descriere' }]) %}{% endif %}
    {% if p.details_html|trim is not empty %}{% set tabs = tabs|merge([{ id: 'caracteristici', label: 'Caracteristici cheie' }]) %}{% endif %}
    {% if specs|length %}{% set tabs = tabs|merge([{ id: 'specificatii', label: 'Specificații' }]) %}{% endif %}
    {% if hasGalerie %}{% set tabs = tabs|merge([{ id: 'galerie', label: 'Galerie' }]) %}{% endif %}
    {% if accCount %}{% set tabs = tabs|merge([{ id: 'accesorii', label: 'Piese & accesorii', count: accCount }]) %}{% endif %}
    {% set activeTab = tabs|length ? tabs[0].id : '' %}

    {% if tabs|length %}
        <div class="ptabs" data-ptabs>
            <div class="container">
                <div class="ptabs__nav" role="tablist">
                    {% for t in tabs %}
                        <button class="ptabs__btn{{ t.id == activeTab ? ' is-active' : '' }}" data-ptab="{{ t.id }}" type="button" role="tab">
                            {{ t.label }}{% if t.count is defined %} <span class="ptabs__count">{{ t.count }}</span>{% endif %}
                        </button>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {# ---------------- Descriere ---------------- #}
    {% if p.description %}
        <div class="ptabs__panel{{ 'descriere' == activeTab ? ' is-active' : '' }}" data-ppanel="descriere">
            <section class="section product-section"><div class="container"><div class="product-prose">
                <h2 class="section__title">Despre {{ p.name }}</h2>
                {{ p.description|raw }}
            </div></div></section>
        </div>
    {% endif %}

    {# ---------------- Caracteristici cheie (details_html) ---------------- #}
    {% if p.details_html|trim is not empty %}
        <div class="ptabs__panel{{ 'caracteristici' == activeTab ? ' is-active' : '' }}" data-ppanel="caracteristici">
            <section class="section product-section"><div class="container"><div class="product-prose">
                <h2 class="section__title">Caracteristici cheie</h2>
                {{ p.details_html|raw }}
            </div></div></section>
        </div>
    {% endif %}

    {# ---------------- Specificații ---------------- #}
    {% if specs|length %}
        <div class="ptabs__panel{{ 'specificatii' == activeTab ? ' is-active' : '' }}" data-ppanel="specificatii">
            <section class="section product-section product-specs"><div class="container">
                <h2 class="section__title">Specificații tehnice</h2>
                <div class="tabs" data-tabs>
                    <div class="tabs__nav" role="tablist">
                        {% for s in specs %}
                            <button class="tabs__btn{{ loop.first ? ' is-active' : '' }}" data-tab="{{ s.id }}" type="button" role="tab">{{ s.label }}</button>
                        {% endfor %}
                    </div>
                    {% for s in specs %}
                        <div class="tabs__panel spec-panel{{ loop.first ? ' is-active' : '' }}" data-panel="{{ s.id }}" role="tabpanel">
                            <div class="spec-table">{{ s.html|raw }}</div>
                        </div>
                    {% endfor %}
                </div>
            </div></section>
        </div>
    {% endif %}

    {# ---------------- Galerie (imagini + video) ---------------- #}
    {% if hasGalerie %}
        <div class="ptabs__panel{{ 'galerie' == activeTab ? ' is-active' : '' }}" data-ppanel="galerie">
            <section class="section product-section"><div class="container">
                <h2 class="section__title">Galerie</h2>
                {% if p.video %}
                    <div class="product-video" data-video data-video-id="{{ p.video }}">
                        <img class="product-video__cover" src="https://i.ytimg.com/vi/{{ p.video }}/maxresdefault.jpg" alt="{{ p.name }} — video"
                             loading="lazy" onerror="this.onerror=null;this.src='https://i.ytimg.com/vi/{{ p.video }}/hqdefault.jpg'">
                        <button class="product-video__play" type="button" data-video-play aria-label="Pornește videoclipul"><span aria-hidden="true">▶</span></button>
                    </div>
                {% endif %}
                {% if galImages|length %}
                    <div class="detail-gallery">
                        {% for d in galImages %}
                            <div class="detail-item media-ph">
                                <img src="{{ base }}{{ d.src }}" alt="{{ p.name }} — imagine {{ loop.index }}" loading="lazy" width="600" height="400"
                                     data-lightbox onerror="this.closest('.detail-item').remove()">
                                <span class="detail-item__zoom" aria-hidden="true">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m17 17 4 4"/><path d="M11 8v6M8 11h6"/></svg>
                                </span>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div></section>
        </div>
    {% endif %}

    {# ---------------- Piese & accesorii ---------------- #}
    {% if accCount %}
    <div class="ptabs__panel{{ 'accesorii' == activeTab ? ' is-active' : '' }}" data-ppanel="accesorii">
        {# ---------------- OEM parts (genuine, manufacturer = brand) ---------------- #}
        {% if oemParts is defined and oemParts|length %}
            <section class="section product-section product-section--oem" id="piese-oem">
                <div class="container">
                    <header class="section__head">
                        <div>
                            <span class="kicker kicker--oem"><span class="tag-oem">OEM</span> Piese originale {{ brandLabel }}</span>
                            <h2 class="section__title">Piese originale pentru {{ p.name }}</h2>
                        </div>
                        {% if bsUrl %}<a class="link-arrow" href="{{ bsUrl }}" target="_blank" rel="noopener">Vezi toate pe BikerShop <span aria-hidden="true">→</span></a>{% endif %}
                    </header>
                    <p class="product-section__lead">Piese de schimb originale {{ brandLabel }}, fabricate de producător, potrivite pentru modelul tău.</p>
                    <div class="grid grid--acc grid--acc--5">
                        {% for a in oemParts %}
                            <a class="card-acc card-acc--sm card-acc--oem" href="{{ a.url }}" target="_blank" rel="noopener">
                                <div class="card-acc__media media-ph media-ph--sm">
                                    {% if a.image %}<img loading="lazy" src="{{ a.image }}" alt="{{ a.name }}" width="300" height="300" onerror="this.closest('.card-acc__media').classList.add('media-ph');this.remove()">{% endif %}
                                </div>
                                <span class="card-acc__brand"><span class="tag-oem">OEM</span> {{ a.manufacturer ?: brandLabel }}</span>
                                <span class="card-acc__name">{{ a.name }}</span>
                                <span class="card-acc__price">{{ a.price|number_format(2, ',', '.') }} Lei</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}

        {# ---------------- Aftermarket accessories & parts ---------------- #}
        {% if accessories is defined and accessories|length %}
            <section class="section product-section" id="accesorii">
                <div class="container">
                    <header class="section__head">
                        <div>
                            <span class="kicker">Aftermarket · BikerShop</span>
                            <h2 class="section__title">Accesorii & echipament compatibile</h2>
                        </div>
                        {% if bsUrl %}<a class="link-arrow" href="{{ bsUrl }}" target="_blank" rel="noopener">Vezi toate pe BikerShop <span aria-hidden="true">→</span></a>{% endif %}
                    </header>
                    <p class="product-section__lead">Piese, consumabile și echipament de la alți producători (aftermarket), compatibile cu modelul tău.</p>
                    <div class="grid grid--acc grid--acc--5">
                        {% for a in accessories %}
                            <a class="card-acc card-acc--sm" href="{{ a.url }}" target="_blank" rel="noopener">
                                <div class="card-acc__media media-ph media-ph--sm">
                                    {% if a.image %}<img loading="lazy" src="{{ a.image }}" alt="{{ a.name }}" width="300" height="300" onerror="this.closest('.card-acc__media').classList.add('media-ph');this.remove()">{% endif %}
                                </div>
                                {% if a.manufacturer %}<span class="card-acc__brand">{{ a.manufacturer }}</span>{% endif %}
                                <span class="card-acc__name">{{ a.name }}</span>
                                <span class="card-acc__price">{{ a.price|number_format(2, ',', '.') }} Lei</span>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            </section>
        {% endif %}
    </div>{# /panel accesorii #}
    {% endif %}

    {# ---------------- Modele similare (sub taburi, mereu vizibil) ---------------- #}
    {% if related|length %}
        <section class="section product-section product-related">
            <div class="container">
                <header class="section__head">
                    <div><span class="kicker">Vezi și</span><h2 class="section__title">Modele similare</h2></div>
                </header>
                <div class="grid grid--models">
                    {% for m in related %}
                        <a class="card-moto" href="{{ base }}{{ m.url }}">
                            <div class="card-moto__media{{ m.image ? '' : ' media-ph' }}">
                                {% if m.year %}<span class="badge">{{ m.year }}</span>{% endif %}
                                {% if m.image %}
                                    <img src="{{ base }}{{ m.image }}" alt="{{ m.name }}" loading="lazy" width="900" height="600"
                                         onerror="this.closest('.card-moto__media').classList.add('media-ph');this.remove()">
                                {% else %}<span class="media-ph__label">{{ m.name }}</span>{% endif %}
                            </div>
                            <div class="card-moto__body">
                                <h3 class="card-moto__name">{{ m.name }}</h3>
                                <div class="card-moto__foot">
                                    {% set rp = prices(m.price) %}
                                    <span class="price"><small>de la</small> {{ rp.eur }}<span class="price__ron">{{ rp.ron }}</span></span>
                                    <span class="link-arrow link-arrow--sm">Detalii <span aria-hidden="true">→</span></span>
                                </div>
                            </div>
                        </a>
                    {% endfor %}
                </div>
            </div>
        </section>
    {% endif %}
</article>

{% include 'partials/lead-modals.twig' with { 'p': p, 'brand': brand, 'brandLabel': brandLabel } %}

{# Financing conditions in a modal (same content as /finantare, which stays as a no-JS fallback). #}
{% if financeCfg and financeCfg.page_html %}
<div class="modal" data-modal="finantare" hidden>
    <div class="modal__overlay" data-modal-close></div>
    <div class="modal__dialog modal__dialog--wide" role="dialog" aria-modal="true" aria-labelledby="modal-title-finantare">
        <button type="button" class="modal__x" data-modal-close aria-label="Închide">&times;</button>
        <div class="modal__body">
            <h2 class="modal__title" id="modal-title-finantare">{{ financeCfg.page_title|default('Finanțare UniCredit') }}</h2>
            <div class="prose finance-prose">{{ financeCfg.page_html|raw }}</div>
        </div>
    </div>
</div>
{% endif %}

{% endblock %}
