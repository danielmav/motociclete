{% extends 'layout.twig' %}

{% block title %}{{ category.name }} {{ brandLabel }} — modele și prețuri | Dual Motors{% endblock %}
{% block description %}{{ category.description ? (category.description|striptags|trim|slice(0, 155)) : ('Descoperă modelele ' ~ category.name ~ ' ' ~ brandLabel ~ ' la Dual Motors — prețuri, dotări și test ride.') }}{% endblock %}

{% block content %}

{% include 'partials/breadcrumb.twig' %}

<section class="section catalog-head">
    <div class="container">
        <span class="kicker">{{ brandLabel }}{% if not isTop %} · {{ crumbs[1].label }}{% endif %}</span>
        <h1 class="catalog-head__title">{{ category.name }}</h1>
        {% if category.description %}
            <div class="catalog-head__lead">{{ category.description|raw }}</div>
        {% endif %}

        {% if isTop and subcategories|length %}
            <ul class="subcat-chips">
                <li><span class="chip chip--active">Toate</span></li>
                {% for s in subcategories %}
                    <li><a class="chip" href="{{ base }}/{{ brand }}/{{ category.slug }}/{{ s.slug }}">{{ s.name }} <small>{{ s.product_count }}</small></a></li>
                {% endfor %}
            </ul>
        {% endif %}
    </div>
</section>

<section class="section section--tight">
    <div class="container">
        {% if facets.licences|length or facets.years|length %}
            <form class="catalog-filters" method="get">
                {% if facets.licences|length %}
                    <label class="catalog-filters__field">
                        <span>Permis</span>
                        <select name="permis" onchange="this.form.submit()">
                            <option value="">Toate</option>
                            {% for l in facets.licences %}
                                <option value="{{ l }}"{{ filters.permis == l ? ' selected' : '' }}>{{ l }}</option>
                            {% endfor %}
                        </select>
                    </label>
                {% endif %}
                {% if facets.years|length %}
                    <label class="catalog-filters__field">
                        <span>An</span>
                        <select name="an" onchange="this.form.submit()">
                            <option value="">Toți anii</option>
                            {% for y in facets.years %}
                                <option value="{{ y }}"{{ filters.an == y ? ' selected' : '' }}>{{ y }}</option>
                            {% endfor %}
                        </select>
                    </label>
                {% endif %}
                <noscript><button class="btn btn--ghost" type="submit">Filtrează</button></noscript>
                {% if filters.permis or filters.an %}
                    {% set resetUrl = isTop ? crumbs[1].url : (crumbs[1].url ~ '/' ~ category.slug) %}
                    <a class="catalog-filters__reset" href="{{ base }}{{ resetUrl }}">Resetează ✕</a>
                {% endif %}
            </form>
        {% endif %}

        {% if products|length %}
            <p class="catalog-count">
                {{ products|length }} {{ products|length == 1 ? 'model' : 'modele' }}
                {% if products|length != total %}<span class="catalog-count__total">din {{ total }}</span>{% endif %}
            </p>
            <div class="grid grid--models" data-cmp-grid data-brand="{{ brand }}">
                {% for m in products %}
                    <a class="card-moto" href="{{ base }}{{ m.url }}">
                        <div class="card-moto__media{{ m.image ? '' : ' media-ph' }}">
                            {% if m.year %}<span class="badge">{{ m.year }}</span>{% endif %}
                            {% if m.old_price %}<span class="badge badge--sale badge--tr">−{{ m.discount }}%</span>{% endif %}
                            <label class="card-compare" data-cmp title="Adaugă la comparație">
                                <input type="checkbox" data-cmp-cb value="{{ m.slug }}" data-name="{{ m.name }}">
                                <span class="card-compare__txt">Compară</span>
                            </label>
                            {% if m.image %}
                                <img src="{{ base }}{{ m.image }}" alt="{{ m.name }}" loading="lazy" width="900" height="600"
                                     onerror="this.closest('.card-moto__media').classList.add('media-ph');this.remove()">
                            {% else %}
                                <span class="media-ph__label">{{ m.name }}</span>
                            {% endif %}
                        </div>
                        <div class="card-moto__body">
                            <div class="card-moto__meta">
                                <span class="chip">{{ m.cat }}</span>
                                {% if m.licence %}<span class="chip chip--permis">Permis {{ m.licence }}</span>{% endif %}
                            </div>
                            <h2 class="card-moto__name">{{ m.name }}</h2>
                            <div class="card-moto__foot">
                                {% set pr = prices(m.price) %}
                                <span class="price">
                                    <small>de la</small>
                                    {{ pr.eur }}
                                    <span class="price__ron">{{ pr.ron }}{% if m.old_price %} · <s>{{ prices(m.old_price).eur }}</s>{% endif %}</span>
                                </span>
                                <span class="link-arrow link-arrow--sm">Detalii <span aria-hidden="true">→</span></span>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state">
                {% if filters.permis or filters.an %}
                    {% set resetUrl = isTop ? crumbs[1].url : (crumbs[1].url ~ '/' ~ category.slug) %}
                    <p>Niciun model nu corespunde filtrelor alese.</p>
                    <a class="btn btn--ghost" href="{{ base }}{{ resetUrl }}">Resetează filtrele <span aria-hidden="true">✕</span></a>
                {% else %}
                    <p>Momentan nu sunt modele în această categorie.</p>
                    <a class="btn btn--ghost" href="{{ base }}/{{ brand }}">Vezi toate modelele {{ brandLabel }} <span aria-hidden="true">→</span></a>
                {% endif %}
            </div>
        {% endif %}
    </div>

    {# Compare tray — populated by JS when models are selected #}
    <div class="cmp-tray" data-cmp-tray hidden>
        <div class="container cmp-tray__inner">
            <span class="cmp-tray__count"><strong data-cmp-count>0</strong> selectate <small>(același brand și categorie)</small></span>
            <div class="cmp-tray__items" data-cmp-items></div>
            <div class="cmp-tray__actions">
                <button type="button" class="btn btn--ghost btn--sm" data-cmp-clear>Golește</button>
                <a class="btn btn--primary btn--sm" data-cmp-go href="#">Compară <span data-cmp-go-n></span></a>
            </div>
        </div>
    </div>
</section>

{% endblock %}
