{% extends 'layout.twig' %}

{% block title %}{{ a.title }} | Blog Dual Motors{% endblock %}
{% block description %}{{ a.excerpt }}{% endblock %}
{% block og_type %}article{% endblock %}

{% block head_extra %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ a.title|json_encode|raw }},
  "description": {{ a.excerpt|json_encode|raw }},
  {% if a.image %}"image": "{{ app.url ~ a.image }}",{% endif %}
  {% if a.date_iso %}"datePublished": "{{ a.date_iso }}",{% endif %}
  "mainEntityOfPage": "{{ app.url ~ base ~ a.url }}",
  "author": { "@type": "Organization", "name": "Dual Motors" },
  "publisher": {
    "@type": "Organization",
    "name": "Dual Motors",
    "logo": { "@type": "ImageObject", "url": "{{ app.url ~ base }}/assets/img/logo.png" }
  }
}
</script>
{% endblock %}

{% block content %}

<section class="section product-section">
    <div class="container article-layout">

        {# ---------------- Main ---------------- #}
        <div class="article">
            <nav class="article__crumbs"><a href="{{ base }}/blog">← Blog</a></nav>
            <span class="card-art__cat">Noutăți{% if a.date %} · {{ a.date }}{% endif %}</span>
            <h1 class="article__title">{{ a.title }}</h1>

            {% if a.image %}
                <figure class="article__cover">
                    <img src="{{ base }}{{ a.image }}" alt="{{ a.title }}" width="1280" height="720" fetchpriority="high"
                         data-lightbox onerror="this.closest('.article__cover').remove()">
                </figure>
            {% endif %}

            <div class="article__body product-prose">{{ a.body|raw }}</div>

            {% if a.images|length %}
                <div class="article__gallery">
                    {% for src in a.images %}
                        <button type="button" class="article__gallery-item" aria-label="Mărește imaginea {{ loop.index }}">
                            <img src="{{ base }}{{ src }}" alt="{{ a.title }} — imagine {{ loop.index }}" loading="lazy" width="400" height="300"
                                 data-lightbox onerror="this.closest('.article__gallery-item').remove()">
                        </button>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        {# ---------------- Sidebar ---------------- #}
        <aside class="article-side">
            {% if more|length %}
                <div class="article-side__box">
                    <h2 class="article-side__title">Mai citește</h2>
                    <ul class="article-side__list">
                        {% for art in more %}
                            {% if art.id != a.id %}
                                <li>
                                    <a class="side-art" href="{{ base }}{{ art.url }}">
                                        <span class="side-art__media{{ art.image ? '' : ' media-ph' }}">
                                            {% if art.image %}<img src="{{ base }}{{ art.image }}" alt="{{ art.title }}" loading="lazy" width="120" height="90"
                                                 onerror="this.closest('.side-art__media').classList.add('media-ph');this.remove()">{% endif %}
                                        </span>
                                        <span class="side-art__body">
                                            {% if art.date %}<span class="side-art__date">{{ art.date }}</span>{% endif %}
                                            <span class="side-art__title">{{ art.title }}</span>
                                        </span>
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                    <a class="link-arrow link-arrow--sm" href="{{ base }}/blog">Tot blogul <span aria-hidden="true">→</span></a>
                </div>
            {% endif %}
        </aside>
    </div>
</section>

{% endblock %}
