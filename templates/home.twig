{% extends 'layout.twig' %}

{% block title %}Dual Motors — Motociclete Yamaha & CFMOTO, echipament moto | motociclete.com.ro{% endblock %}
{% block description %}Dealer autorizat Yamaha și CFMOTO și importator oficial Arai, Dainese, AGV, TCX, MOMO, Putoline, Twin Air. Showroom Pipera București, drive test online și piese filtrate pe motocicleta ta.{% endblock %}

{% block content %}

{# ============ HERO (4-slide rotator) ============ #}
<section class="herov2" data-hero-slider aria-roledescription="carousel" aria-label="Prezentare showroom">
    <div class="herov2__bg" aria-hidden="true"></div>

    <div class="container herov2__slides">
        {% for s in heroSlides %}
            <article class="herov2__slide{{ loop.first ? ' is-active' }}" data-hero-slide="{{ loop.index0 }}" aria-hidden="{{ loop.first ? 'false' : 'true' }}">
                <div class="herov2__grid">
                    <div class="herov2__copy">
                        <span class="kicker" data-hero-anim>{{ s.kicker }}</span>
                        <h1 class="herov2__title" data-hero-anim>{{ s.titleHtml|raw }}</h1>
                        <p class="herov2__sub" data-hero-anim>{{ s.sub }}</p>
                        <div class="herov2__cta" data-hero-anim>
                            <a class="btn btn--primary btn--lg" href="{{ base }}{{ s.cta.href }}">{{ s.cta.label }}</a>
                            <a class="btn btn--ghost btn--lg" href="{{ testride_url }}">Programează drive test <span aria-hidden="true">→</span></a>
                        </div>
                        {% if s.stats %}
                            <dl class="herov2__stats" data-hero-anim>
                                {% for st in s.statsList %}<div><dt>{{ st.value }}</dt><dd>{{ st.label }}</dd></div>{% endfor %}
                            </dl>
                        {% endif %}
                    </div>

                    <div class="herov2__stage" data-hero-anim>
                        {% set isAbs = s.image starts with 'http' %}
                        <div class="herov2__media{{ s.image ? '' : ' media-ph' }}">
                            <img src="{{ isAbs ? s.image : base ~ s.image }}" alt="{{ s.imageAlt }}" width="1600" height="900"
                                 {{ loop.first ? 'fetchpriority="high"' : 'loading="lazy"' }}
                                 onerror="this.closest('.herov2__media').classList.add('media-ph');this.remove()">
                            <span class="media-corner" aria-hidden="true"></span>
                        </div>
                        <span class="herov2__ghost" aria-hidden="true">{{ s.ghost }}</span>
                    </div>
                </div>
            </article>
        {% endfor %}
    </div>

    <div class="container herov2__controls">
        <div class="herov2__dots" role="tablist" aria-label="Slide-uri">
            {% for s in heroSlides %}
                <button class="herov2__dot{{ loop.first ? ' is-active' }}" type="button" data-hero-dot="{{ loop.index0 }}" role="tab" aria-label="Slide {{ loop.index }}" aria-selected="{{ loop.first ? 'true' : 'false' }}"></button>
            {% endfor %}
        </div>
        <div class="herov2__arrows">
            <button class="herov2__arrow" type="button" data-hero-prev aria-label="Slide-ul anterior">‹</button>
            <button class="herov2__arrow" type="button" data-hero-next aria-label="Slide-ul următor">›</button>
        </div>
    </div>
</section>

{# ============ BRAND MARQUEE ============ #}
<section class="marquee" aria-label="Branduri partenere">
    <div class="marquee__track">
        {% for label, names in brands %}{% for n in names %}<span class="marquee__item">{{ n }}</span><span class="marquee__dot" aria-hidden="true">•</span>{% endfor %}{% endfor %}
        {% for label, names in brands %}{% for n in names %}<span class="marquee__item" aria-hidden="true">{{ n }}</span><span class="marquee__dot" aria-hidden="true">•</span>{% endfor %}{% endfor %}
    </div>
</section>

{# ============ FEATURED MODELS ============ #}
<section class="section" id="modele">
    <div class="container">
        <header class="section__head">
            <div>
                <span class="kicker">Gama 2026</span>
                <h2 class="section__title">Modele de pus în garaj</h2>
            </div>
            <a class="link-arrow" href="{{ base }}/motociclete">Toate motocicletele <span aria-hidden="true">→</span></a>
        </header>

        <div class="grid grid--models">
            {% for m in models %}
                <a class="card-moto" href="{{ base }}{{ m.url }}">
                    <div class="card-moto__media{{ m.image ? '' : ' media-ph' }}">
                        {% if m.year %}<span class="badge">{{ m.year }}</span>{% endif %}
                        {% if m.promo %}<span class="ribbon-promo">Promoție</span>{% endif %}
                        {% if m.image %}
                            <img src="{{ base }}{{ m.image }}" alt="{{ m.name }}" loading="lazy" width="900" height="600"
                                 onerror="this.closest('.card-moto__media').classList.add('media-ph');this.remove()">
                        {% else %}
                            <span class="media-ph__label">{{ m.name }}</span>
                        {% endif %}
                    </div>
                    <div class="card-moto__body">
                        <div class="card-moto__meta">
                            <span class="chip">{{ m.cat }}</span>
                            {% if m.licence %}<span class="chip chip--permis">Permis {{ m.licence }}</span>{% endif %}
                        </div>
                        <h3 class="card-moto__name">{{ m.name }}</h3>
                        <div class="card-moto__foot">
                            {% if m.price %}
                                {% set pr = prices(m.price, m.brand) %}
                                <span class="price"><small>de la</small> {{ pr.eur }}<span class="price__ron">{{ pr.ron }}</span></span>
                            {% endif %}
                            <span class="link-arrow link-arrow--sm">Detalii <span aria-hidden="true">→</span></span>
                        </div>
                    </div>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

{# ============ FIT MY BIKE + ACCESSORIES (BikerShop) ============ #}
<section class="fitbike" id="fit">
    <div class="container fitbike__grid">
        <div class="fitbike__intro">
            <span class="kicker kicker--light">Fit My Bike</span>
            <h2 class="fitbike__title">Spune-ne ce motocicletă ai.<br>Îți arătăm doar ce se potrivește.</h2>
            <p class="fitbike__text">Piesele și echipamentul vin live din <strong>BikerShop</strong> — sute de mii de produse, filtrate automat pe motocicleta ta, fără să mai cauți manual.</p>

            <form class="fitbike__form" data-fit>
                <label>Marcă
                    <select name="make" data-fit-make>
                        <option value="">Alege marca…</option>
                        {% for m in makes %}<option value="{{ m.id }}">{{ m.name }}</option>{% endfor %}
                    </select>
                </label>
                <label>Model
                    <select name="model" data-fit-model disabled>
                        <option value="">Alege întâi marca</option>
                    </select>
                </label>
                <label>An
                    <select name="year" data-fit-year disabled>
                        <option value="">Toți anii</option>
                    </select>
                </label>
                <button class="btn btn--primary" type="submit" data-fit-submit disabled>Arată produsele</button>
            </form>
        </div>

        <div class="fitbike__results">
            <div class="fitbike__results-head">
                <span data-fit-title>{{ accessoriesLive ? 'Accesorii din BikerShop' : 'Produse compatibile' }}</span>
                {% if accessoriesLive %}
                    <span class="dot-live" data-fit-status>live din BikerShop</span>
                {% else %}
                    <span class="dot-demo">previzualizare — conectează BikerShop</span>
                {% endif %}
            </div>

            <div class="grid grid--acc" data-fit-results>
                {% if accessories|length %}
                    {% for a in accessories %}
                        <a class="card-acc" href="{{ a.url }}" target="_blank" rel="noopener">
                            <div class="card-acc__media media-ph media-ph--sm">
                                {% if a.image %}<img loading="lazy" src="{{ a.image }}" alt="{{ a.name }}" width="300" height="300">{% else %}<span class="media-ph__label">{{ a.manufacturer }}</span>{% endif %}
                            </div>
                            <span class="card-acc__brand">{{ a.manufacturer }}</span>
                            <span class="card-acc__name">{{ a.name }}</span>
                            <span class="card-acc__price">{{ a.price|number_format(2, ',', '.') }} Lei</span>
                        </a>
                    {% endfor %}
                {% else %}
                    {% for i in 1..6 %}
                        <div class="card-acc card-acc--ph">
                            <div class="card-acc__media media-ph media-ph--sm"><span class="media-ph__label">Produs</span></div>
                            <span class="card-acc__brand">BikerShop</span>
                            <span class="card-acc__name skeleton-line"></span>
                            <span class="card-acc__price skeleton-line skeleton-line--sm"></span>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>

            <a class="btn btn--ghost fitbike__all" data-fit-bikershop target="_blank" rel="noopener" hidden>Vezi toate produsele pe BikerShop <span aria-hidden="true">→</span></a>
        </div>
    </div>
</section>

{# ============ VIRTUAL TOUR ============ #}
<section class="tour" id="tur">
    <div class="container">
        <div class="tour__frame" data-tour data-tour-url="{{ tour.url }}">
            <img class="tour__poster" src="{{ base }}{{ tour.image }}" alt="Showroom Dual Motors Pipera" loading="lazy" width="1600" height="900">
            <div class="tour__overlay">
                <span class="kicker kicker--light">Tur virtual 360°</span>
                <h2 class="tour__title">Vizitează showroom-ul fără să pleci de acasă</h2>
                <button class="btn btn--primary btn--lg" type="button" data-tour-play>
                    <span class="tour__play" aria-hidden="true">▶</span> Pornește turul virtual
                </button>
            </div>
        </div>
    </div>
</section>

{# ============ EDITORIAL ============ #}
<section class="section blog-home" id="blog">
    <div class="container">
        <header class="section__head">
            <div>
                <span class="kicker">Pe Două Roți</span>
                <h2 class="section__title">Ghiduri, review-uri, drumuri</h2>
            </div>
            <a class="link-arrow" href="{{ base }}/blog">Tot blogul <span aria-hidden="true">→</span></a>
        </header>

        {% if articles|length %}
            <div class="grid grid--articles">
                {% for art in articles %}
                    <a class="card-art" href="{{ base }}{{ art.url }}">
                        <div class="card-art__media{{ art.image ? '' : ' media-ph' }}">
                            {% if art.image %}
                                <img src="{{ base }}{{ art.image }}" alt="{{ art.title }}" loading="lazy" width="640" height="400"
                                     onerror="this.closest('.card-art__media').classList.add('media-ph');this.remove()">
                            {% else %}<span class="media-ph__label">Pe Două Roți</span>{% endif %}
                        </div>
                        <span class="card-art__cat">Noutăți{% if art.date %} · {{ art.date }}{% endif %}</span>
                        <h3 class="card-art__title">{{ art.title }}</h3>
                    </a>
                {% endfor %}
            </div>
        {% else %}
            <div class="empty-state"><p>Momentan nu sunt articole de afișat.</p></div>
        {% endif %}
    </div>
</section>

{# ============ DRIVE TEST BAND ============ #}
<section class="ride">
    <div class="container ride__inner">
        <div class="ride__copy">
            <span class="kicker kicker--light">Drive test online</span>
            <h2 class="ride__title">Alege ziua, modelul și ora.<br>Te urci pe ea.</h2>
            <p class="ride__text">Rezervare în câțiva pași, confirmare pe e-mail și SMS. Vino în showroom și condu modelul care îți place.</p>
        </div>
        <a class="btn btn--primary btn--lg" href="{{ testride_url }}">Programează drive test <span aria-hidden="true">→</span></a>
    </div>
</section>

{% endblock %}
