# motociclete.com.ro - front controller routing (Laragon docroot = project root)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Post-relaunch: the staging lived at /2026. Once this app is the docroot
    # root, 301 any leftover /2026/* request (indexed staging URLs) to the root.
    # In the /2026 subfolder context this segment is stripped, so staging is
    # unaffected while it still exists.
    RewriteRule ^2026/(.*)$ /$1 [R=301,L]
    RewriteRule ^2026/?$ / [R=301,L]

    # Block direct access to application internals
    # (.git + database adăugate: la deploy prin cPanel Git, .git ajunge în docroot)
    RewriteRule ^(src|templates|config|storage|vendor|documente|node_modules|database|\.git)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|\.env.*|\.cpanel\.yml|CLAUDE\.md|.*\.md)$ - [F,L]

    # Serve real existing files / directories directly (assets, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else through the front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Sensible caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType font/woff2 "access plus 365 days"
</IfModule>
