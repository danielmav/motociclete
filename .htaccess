# motociclete.com.ro - front controller routing (Laragon docroot = project root)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Local only: let the /2026 demo build be served by its own .htaccess
    RewriteRule ^2026/ - [L]

    # Block direct access to application internals
    RewriteRule ^(src|templates|config|storage|vendor|documente|node_modules)/ - [F,L]
    RewriteRule ^(composer\.(json|lock)|\.env.*|CLAUDE\.md|.*\.md)$ - [F,L]

    # Serve real existing files / directories directly (assets, etc.)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route everything else through the front controller
    RewriteRule ^ index.php [QSA,L]
</IfModule>

# Sensible caching for static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/avif "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType font/woff2 "access plus 365 days"
</IfModule>
